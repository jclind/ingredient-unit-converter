{
  "name": "@jclind/ingredient-unit-converter",
  "version": "1.0.6",
  "description": "Converts between common ingredient units",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && printf '{\"type\":\"module\"}' > dist/esm/package.json && printf '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jclind/ingredient-unit-converter.git"
  },
  "author": "Jesse Lind",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jclind/ingredient-unit-converter/issues"
  },
  "homepage": "https://github.com/jclind/ingredient-unit-converter#readme",
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^3.1.3"
  }
}
